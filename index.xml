&lt;pre&gt;&lt;code&gt;wget https://www.geckosweb.cn/geckos/{版本号}/geckos.zip&lt;/code&gt;&lt;/pre&gt;&lt;ol start="2"&gt;
&lt;li&gt;解压到位&lt;/li&gt;
&lt;/ol&gt;
&lt;pre&gt;&lt;code&gt;unzip geckos.zip -d /opt/geckos
chmod &amp;#43;x /opt/geckos/geckos&lt;/code&gt;&lt;/pre&gt;&lt;ol start="3"&gt;
&lt;li&gt;加个全局命令&lt;/li&gt;
&lt;/ol&gt;
&lt;pre&gt;&lt;code&gt;ln -s /opt/geckos/geckos /usr/local/bin/geckos&lt;/code&gt;&lt;/pre&gt;&lt;ol start="4"&gt;
&lt;li&gt;
&lt;p&gt;配置文件已在程序目录，无需额外操作&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;注册 systemd 服务&lt;/p&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;pre&gt;&lt;code&gt;cat &amp;gt; /etc/systemd/system/geckos.service &amp;lt;&amp;lt; &amp;#39;EOF&amp;#39;
[Unit]
Description=Geckos Web OS
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/geckos
ExecStart=/opt/geckos/geckos serve
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF&lt;/code&gt;&lt;/pre&gt;&lt;ol start="6"&gt;
&lt;li&gt;启动！&lt;/li&gt;
&lt;/ol&gt;
&lt;pre&gt;&lt;code&gt;systemctl daemon-reload
systemctl enable geckos
systemctl start geckos&lt;/code&gt;&lt;/pre&gt;&lt;ol start="7"&gt;
&lt;li&gt;创建数据目录&lt;/li&gt;
&lt;/ol&gt;
&lt;pre&gt;&lt;code&gt;mkdir -p /geckosdata
chmod 755 /geckosdata&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;搞定，打开浏览器访问吧 🎉&lt;/p&gt;
